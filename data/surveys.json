      "id": "csat-2025",
      "title": "Customer Satisfaction Survey",
      "description": "Quarterly feedback on product quality, support experience, and overall satisfaction.",
      "createdAt": "2025-03-01",
      "status": "active",
      "questions": [
        {
          "id": "q1",
          "text": "How satisfied are you with our product overall?",
          "type": "rating",
          "scale": { "min": 1, "max": 5, "labels": ["Very Dissatisfied", "Dissatisfied", "Neutral", "Satisfied", "Very Satisfied"] }
        },
        {
          "id": "q2",
          "text": "Which features do you use most frequently?",
          "type": "multiple-choice",
          "options": ["Dashboard", "Reports", "Integrations", "API Access", "Mobile App", "Team Collaboration"],
          "allowMultiple": true
        },
        {
          "id": "q3",
          "text": "How would you rate our customer support?",
          "type": "rating",
          "scale": { "min": 1, "max": 5, "labels": ["Very Poor", "Poor", "Average", "Good", "Excellent"] }
        },
        {
          "id": "q4",
          "text": "How likely are you to recommend us to a colleague?",
          "type": "nps",
          "scale": { "min": 0, "max": 10 }
        },
        {
          "id": "q5",
          "text": "What is your primary reason for using our product?",
          "type": "single-choice",
          "options": ["Time Savings", "Cost Reduction", "Better Insights", "Team Alignment", "Compliance", "Other"]
        },
        {
          "id": "q6",
          "text": "How easy is the product to use?",
          "type": "rating",
          "scale": { "min": 1, "max": 5, "labels": ["Very Difficult", "Difficult", "Moderate", "Easy", "Very Easy"] }
        },
        {
          "id": "q7",
          "text": "What could we improve?",
          "type": "free-text"
        }
      ]
    },
